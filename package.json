{
  "name": "pdfcraftai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-all-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:fixtures": "node tests/fixtures/generate.mjs",
    "test:prod-e2e": "playwright test --config=playwright.prod.config.ts",
    "test:prod-e2e:ui": "playwright test --config=playwright.prod.config.ts --ui",
    "test:ops": "tsx scripts/test-pdf-ops.ts",
    "smoke": "node scripts/smoke-live.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prebuild": "node scripts/copy-pdfjs-worker.mjs && node scripts/copy-pdfium-wasm.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@auth/drizzle-adapter": "1.7.4",
    "@google/generative-ai": "^0.24.1",
    "@hyzyla/pdfium": "^2.1.12",
    "bcryptjs": "2.4.3",
    "docx": "^9.6.1",
    "drizzle-orm": "0.36.4",
    "geist": "1.3.1",
    "jszip": "^3.10.1",
    "lucide-react": "0.454.0",
    "mysql2": "3.11.4",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.22",
    "next-intl": "^3.26.5",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cantoo/pdf-lib": "^2.6.5",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.28.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "tsx": "^4.21.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
